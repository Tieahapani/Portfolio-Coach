# Required: At least one LLM provider
GEMINI_API_KEY=your_gemini_key_here          # Free at aistudio.google.com
ANTHROPIC_API_KEY=your_anthropic_key_here    # For Claude + Indeed MCP

# Optional
GITHUB_TOKEN=your_github_pat_here            # For private repos + higher rate limits

# Server
HOST=0.0.0.0
PORT=8000

# Security
JWT_SECRET=generate_a_long_random_string     # e.g. python -c "import secrets; print(secrets.token_hex(32))"
