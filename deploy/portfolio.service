[Unit]
Description=Portfolio Coach
After=network.target

[Service]
WorkingDirectory=/opt/portfolio-coach
ExecStart=/opt/portfolio-coach/venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --proxy-headers --forwarded-allow-ips 127.0.0.1
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
